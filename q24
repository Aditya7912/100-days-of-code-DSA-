#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

// Insert at end
Node* insert(Node* head, int x) {
    Node* newNode = new Node();
    newNode->data = x;
    newNode->next = NULL;

    if(head == NULL)
        return newNode;

    Node* temp = head;
    while(temp->next != NULL)
        temp = temp->next;

    temp->next = newNode;
    return head;
}

// Delete first occurrence of key
Node* deleteKey(Node* head, int key) {
    if(head == NULL)
        return head;

    // If head node contains key
    if(head->data == key) {
        Node* temp = head;
        head = head->next;
        delete temp;
        return head;
    }

    Node* curr = head;
    Node* prev = NULL;

    while(curr != NULL && curr->data != key) {
        prev = curr;
        curr = curr->next;
    }

    if(curr != NULL) {
        prev->next = curr->next;
        delete curr;
    }

    return head;
}

// Print linked list
void printList(Node* head) {
    while(head != NULL) {
        cout << head->data << " ";
        head = head->next;
    }
}

int main() {
    int n, key, x;
    Node* head = NULL;

    cin >> n;

    for(int i = 0; i < n; i++) {
        cin >> x;
        head = insert(head, x);
    }

    cin >> key;

    head = deleteKey(head, key);

    printList(head);

    return 0;
}
