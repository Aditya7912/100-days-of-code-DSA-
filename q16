#include <iostream>
#include <unordered_map>
using namespace std;

int main() {
    int n;
    cin >> n;

    unordered_map<int, int> freq;
    int num;

    for(int i = 0; i < n; i++) {
        cin >> num;
        freq[num]++;
    }

    for(auto it : freq) {
        cout << it.first << ":" << it.second << " ";
    }

    return 0;
}
